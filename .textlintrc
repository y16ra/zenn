{
    "plugins": {
        "@textlint/markdown": {
            "extensions": [
                ".md"
            ]
        }
    },
    "filters": {
        "comments": true,
        "allowlist": {
            "allow": [
                "ML",
                "AI",
                "LLM",
                "NLP",
                "RAG",
                "ROI",
                "API",
                "OCR"
            ]
        }
    },
    "rules": {
        "textlint-rule-no-mix-dearu-desumasu": true,
        "textlint-rule-max-ten": true,
        "textlint-rule-spellcheck-tech-word": true,
        "preset-ja-technical-writing": true
    }
}
